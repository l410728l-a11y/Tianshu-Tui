{
  "name": "tianshu-vscode",
  "displayName": "天枢 Tianshu",
  "description": "天枢 agent 座舱 — DeepSeek 前缀缓存优化的终端编程智能体，VS Code / Cursor 插件端",
  "version": "0.3.0",
  "publisher": "tianshu",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "keywords": [
    "tianshu",
    "ai",
    "coding-agent",
    "deepseek",
    "cursor",
    "agent"
  ],
  "homepage": "https://github.com/huiliyi37/Tianshu-Tui#readme",
  "bugs": {
    "url": "https://github.com/huiliyi37/Tianshu-Tui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/huiliyi37/Tianshu-Tui"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tianshu",
          "title": "天枢",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "tianshu": [
        {
          "type": "webview",
          "id": "tianshu.cockpit",
          "name": "座舱"
        },
        {
          "id": "tianshu.changes",
          "name": "变更审查"
        }
      ]
    },
    "commands": [
      {
        "command": "tianshu.newSession",
        "title": "天枢: 新建会话"
      },
      {
        "command": "tianshu.restartSidecar",
        "title": "天枢: 重启内核 sidecar"
      },
      {
        "command": "tianshu.showSidecarLog",
        "title": "天枢: 查看内核日志"
      },
      {
        "command": "tianshu.refreshChanges",
        "title": "天枢: 刷新变更",
        "icon": "$(refresh)"
      },
      {
        "command": "tianshu.rollback",
        "title": "天枢: 回滚到 checkpoint",
        "icon": "$(discard)"
      },
      {
        "command": "tianshu.sendSelection",
        "title": "发送到天枢"
      },
      {
        "command": "tianshu.inlineEdit",
        "title": "天枢: 行内编辑 (Ctrl+K)"
      },
      {
        "command": "tianshu.acceptEdit",
        "title": "天枢: 接受委托编辑"
      },
      {
        "command": "tianshu.rejectEdit",
        "title": "天枢: 拒绝委托编辑"
      },
      {
        "command": "tianshu.generateCommitMessage",
        "title": "天枢: 生成提交语",
        "icon": "$(sparkle)"
      }
    ],
    "keybindings": [
      {
        "command": "tianshu.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tianshu.sendSelection",
          "group": "tianshu@1"
        },
        {
          "command": "tianshu.inlineEdit",
          "group": "tianshu@2"
        }
      ],
      "view/title": [
        {
          "command": "tianshu.refreshChanges",
          "when": "view == tianshu.changes",
          "group": "navigation@1"
        },
        {
          "command": "tianshu.rollback",
          "when": "view == tianshu.changes",
          "group": "navigation@2"
        }
      ],
      "scm/title": [
        {
          "command": "tianshu.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "天枢",
      "properties": {
        "tianshu.cliPath": {
          "type": "string",
          "default": "",
          "description": "rivet CLI 可执行文件路径（留空则自动探测 PATH）"
        },
        "tianshu.serverPort": {
          "type": "number",
          "default": 0,
          "description": "sidecar 端口（0 = 自动选择空闲端口）"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"tests/*.test.ts\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.7"
  }
}
